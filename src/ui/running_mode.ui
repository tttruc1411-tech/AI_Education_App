    #consoleHeader { background-color: #f1f5f9; border-bottom: 1px solid #e2e8f0; border-top: 1px solid #e2e8f0; }
    #collapsedConsoleBar { background-color: #f1f5f9; border-top: 1px solid #e2e8f0; }
