    #btnLoadFaceDetect, #btnLoadObjectDetect, #btnLoadLLMChatbot { background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #3b82f6, stop:1 #7c3aed); color: white; border-radius: 10px; font-weight: bold; padding: 2px 12px; min-height: 32px; min-width: 70px; border: none; font-size: 14px; }
    #btnLoadFaceDetect:hover, #btnLoadObjectDetect:hover, #btnLoadLLMChatbot:hover { background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #2563eb, stop:1 #6d28d9); }
    QScrollArea { border: none; background: #faf7f2; }
