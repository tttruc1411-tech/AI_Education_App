    #exampleDesc { color: #475569; font-size: 14px; }
    #exampleBadge1 { background: #f6710b; color: white; border-radius: 6px; padding: 2px 8px; font-size: 12px; font-weight: bold; min-width: 60px; max-width: 80px; min-height: 22px; max-height: 22px; }
    #exampleBadge2 { background: #08a54f; color: white; border-radius: 6px; padding: 2px 8px; font-size: 12px; font-weight: bold; min-width: 60px; max-width: 80px; min-height: 22px; max-height: 22px; }
