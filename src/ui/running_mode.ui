    #tabExamples:checked, #tabFunctions:checked, #tabWorkspace:checked { background-color: white; color: #7c3aed; border: 2px solid #7c3aed; }
    #tabExamples:hover:!checked, #tabFunctions:hover:!checked, #tabWorkspace:hover:!checked { background-color: #7c3aed; }
    #hubStackedWidget, #pageExamples, #pageFunctions, #pageWorkspace { background: transparent; border: none; }
