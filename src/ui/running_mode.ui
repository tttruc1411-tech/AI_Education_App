    #editorTabBar { background-color: #1f2937; }
    #monacoPlaceholder { color: #1e293b; font-family: Consolas, monospace; font-size: 16px; padding: 10px; border: none; background-color: #faf7f2; }
    #consoleBody { background-color: #0f172a; color: #5ff97b; font-family: 'Consolas', monospace; font-size: 15px; border: none; padding: 10px; }
    #camHeader { background-color: #0ea5e9; border: none; }
