<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TrainingMode</class>
 <widget class="QWidget" name="TrainingMode">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>700</height>
   </rect>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* FIX: Removed global white background and made labels transparent */
    QWidget { font-family: 'Segoe UI', Arial, sans-serif; }
    TrainingMode { background-color: #f1f5f9; }
    QLabel { background: transparent; }
    
    #leftPanel, #configPanel, #progressPanel, #rightPanel { background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; }
    
    /* ================= Vibrant Ombre Headers ================= */
    QFrame#leftHeader, QFrame#configHeader, QFrame#progressHeader, QFrame#rightHeader {
        border-top-left-radius: 11px; border-top-right-radius: 11px;
    }
    
    /* The continuous Navy -&gt; Purple -&gt; Pink -&gt; Blue ombre flow */
    QFrame#leftHeader { background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #1e3a8a, stop:1 #7e22ce); }
    QFrame#configHeader { background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #7e22ce, stop:1 #ec4899); }
    QFrame#progressHeader { background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #ec4899, stop:1 #3b82f6); }
    QFrame#rightHeader { background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3b82f6, stop:1 #1e3a8a); }

    QLabel#panelTitle, #configHeader QLabel, #progressHeader QLabel, #rightHeader QLabel{ 
        font-size: 20px; font-weight: bold; color: white; padding: 6px 16px; 
        background: transparent;
    }
    
    QFrame#leftHeader QLabel#panelTitle { padding-bottom: 4px; }

    /* ================= Buttons ================= */
    QPushButton#btnAddClass { 
        border: 2px dashed #cbd5e1; background: #f8fafc; color: #64748b; 
        border-radius: 8px; padding: 12px; font-weight: bold; margin: 8px; font-size: 16px;
    }
    QPushButton#btnAddClass:hover { background: #f1f5f9; border-color: #3b82f6; color: #3b82f6; }

    QPushButton#btnRecognition, QPushButton#btnDetection { 
        background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); 
        border-radius: 8px; padding: 5px 13px; font-weight: 800; color: #e0e7ff; font-size: 12px;
    }
    QPushButton#btnRecognition:hover:!checked, QPushButton#btnDetection:hover:!checked { background: rgba(255, 255, 255, 0.3); }
    QPushButton#btnRecognition:checked, QPushButton#btnDetection:checked { background: white; color: #4338ca; border-color: white; }

    /* Compact 'Segmented' Size Buttons */
    QPushButton#btnCapSize320, QPushButton#btnCapSize640 { 
        background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.2); 
        padding: 3px 8px; font-weight: bold; font-size: 11px; color: #cbd5e1; 
    }
    QPushButton#btnCapSize320 { border-top-left-radius: 8px; border-bottom-left-radius: 8px; border-right: none; }
    QPushButton#btnCapSize640 { border-top-right-radius: 8px; border-bottom-right-radius: 8px; }

    QPushButton#btnCapSize320:hover:!checked, QPushButton#btnCapSize640:hover:!checked { background: rgba(255, 255, 255, 0.25); }
    QPushButton#btnCapSize320:checked, QPushButton#btnCapSize640:checked { background: white; color: #3b82f6; border-color: white; }

    QPushButton#btnStartTraining {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #16a34a, stop:1 #059669);
        color: white; border-radius: 8px; font-weight: bold; border: none;
        min-height: 36px; font-size: 16px; margin: 8px;
    }
    QPushButton#btnStartTraining:hover { background-color: #15803d; }
    QPushButton#btnStartTraining:disabled { background: #94a3b8; }

    /* ================= Forms and Misc ================= */
    QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
        border: 1px solid #e2e8f0; border-radius: 6px; padding: 4px 10px;
        background-color: #f8fafc; font-size: 14px; color: #0f172a; min-height: 28px;
    }
    QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus { border: 1px solid #3b82f6; background-color: white; }

    /* Override for compact project name input in header */
    QLineEdit#editProjName { min-height: 0px; max-height: 26px; padding: 0px 4px; font-size: 11px; }
    
    QLabel#lblBackbone, QLabel#lblEpochs, QLabel#lblBatch, QLabel#lblLR, QLabel#lblOpt, QLabel#lblImgSize { font-weight: bold; font-size: 15px; color: #1e293b; background: transparent; }

    QFrame#metricCard { border-radius: 8px; padding: 10px; border: 1px solid rgba(0,0,0,0.05); }
    QLabel#metricTitle { color: rgba(0,0,0,0.6); font-size: 14px; font-weight: bold; background: transparent; }
    QLabel#metricValue { color: #0f172a; font-size: 20px; font-weight: bold; background: transparent; }
    
    QScrollArea { border: none; background: transparent; }
    QScrollArea QWidget { background: transparent; }
    
    QSplitter::handle:horizontal {
        background-color: #3b82f6;
        width: 2px;
    }
    QSplitter::handle:vertical {
        background-color: #8b5cf6;
        height: 2px;
        margin: 0px 3px;
        border-radius: 10px;
    }
   </string>
  </property>
