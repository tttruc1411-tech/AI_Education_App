     <widget class="QFrame" name="rightPanel">
      <property name="minimumSize"><size><width>200</width><height>0</height></size></property>
      <property name="maximumSize"><size><width>1200</width><height>16777215</height></size></property>
      <layout class="QVBoxLayout" name="rightLayout">
       <property name="spacing"><number>0</number></property>
       <property name="leftMargin"><number>0</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>0</number></property>
       <property name="bottomMargin"><number>0</number></property>
       
       <item>
        <widget class="QFrame" name="rightHeader">
