  <property name="styleSheet">
   <string notr="true">
    /* Global Styles */
    QWidget { font-family: 'Segoe UI', Arial, sans-serif; }
    QMainWindow { background-color: #1e1e2f; }
    
    /* Top Header Gradient (Matches Figma exactly) */
    #headerFrame { 
        background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #8b5cf6, stop:0.5 #d946ef, stop:1 #3b82f6); 
    }
    #appTitle { color: white; font-size: 22px; font-weight: bold; }
    #appSubtitle { color: rgba(255,255,255,0.8); font-size: 12px; }
    
    /* Toggle Switch Container (Slightly darkened to make the glass pop) */
    #toggleContainer { 
        background-color: rgba(0, 0, 0, 0.15); 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 18px; 
    }
    
    /* Toggle Buttons - Default State */
    #btnRunMode, #btnTrainMode {
        background-color: transparent; 
        color: rgba(255, 255, 255, 0.7); 
        border-radius: 14px; 
        font-weight: bold; 
        padding: 6px 16px;
        border: 1px solid transparent; 
    }
    
    /* Toggle Buttons - Active State (Glass Design) */
    #btnRunMode:checked, #btnTrainMode:checked {
        background-color: rgba(255, 255, 255, 0.25); 
        border: 1px solid rgba(255, 255, 255, 0.6);  
        color: white; 
    }
    
    /* Hover effects for unselected buttons */
    #btnRunMode:hover:!checked, #btnTrainMode:hover:!checked {
        background-color: rgba(255, 255, 255, 0.1);
    }
    
    /* Language Toggle Switch (Vibrant and Styled) */
    #langToggleContainer { 
        background-color: rgba(0, 0, 0, 0.15); 
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 18px; 
    }
    
    #btnLangEN, #btnLangVN {
        background-color: transparent; 
        color: rgba(255, 255, 255, 0.7); 
        border-radius: 14px; 
        font-weight: bold; 
        font-size: 16px;
        padding: 4px 10px;
        border: 1px solid transparent; 
    }
    
    #btnLangEN:checked, #btnLangVN:checked {
        background-color: rgba(255, 255, 255, 0.25); 
        border: 1px solid rgba(255, 255, 255, 0.6);  
        color: white; 
    }
    
    #btnLangEN:hover:!checked, #btnLangVN:hover:!checked {
        background-color: rgba(255, 255, 255, 0.1);
    }
    
    /* Footer */
    #footerFrame { 
        background-color: #1f2937; 
        color: #9ca3af; 
        font-size: 12px; 
    }
   </string>
